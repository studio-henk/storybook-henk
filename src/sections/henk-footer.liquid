        {%- for policy in shop.policies -%}
          {%- if policy != blank -%}
            <li class="henk-footer__small-print-item">
              <a class="footer__link" href="{{ policy.url }}">
                <small>{{- policy.title | escape -}}</small>
              </a>
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
