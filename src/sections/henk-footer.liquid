{% assign footer_menu = linklists.footer %}
<div class="henk-footer__container">
  <h2 class="visually-hidden">Footer</h2>
  <div class="henk-footer__row henk-footer__row--links">
    <div class="henk-footer__grid">
      {% comment %} {% for link in linklists.footer.links %} {% endcomment %}
      {% for link in footer_menu.links %}
        <div class="henk-footer__grid-column">
          <h3 class="henk-footer__heading fw-medium">
            <a href="{{ link.url }}">{{ link.title }}</a>
          </h3>
          {% if link.links %}
            <ul class="henk-footer__list henk-list henk-list--no-bullets">
              {% for drop in link.links %}
                <li class="henk-footer__list-item">
                  <a href="{{ drop.url }}">
                    {{- drop.title -}}
                  </a>
                </li>
              {% endfor %}
            </ul>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
  {% comment %} row b-corp, trustpilot {% endcomment %}
  <div class="henk-footer__row henk-footer__row--social-rating">
    <div class="henk-footer__section henk-footer__section--rating">
      <h3 class="henk-footer__heading h4 visually-hidden">Bcorp and Rating</h3>
      <div class="henk-footer__certificates-rating">
        <a
          href="https://www.bcorporation.net/en-us/find-a-b-corp/company/studio-henk/"
          title="Bcorp"
        >
          {% render 'henk-asset-logo-bcorp' %}
